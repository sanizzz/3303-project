@startuml
title Iteration 4 Timing Diagram

' Main.TIME_SCALE = 20
' Scheduler wait = 200 ms
' Drone tick = 100 ms
' Soft reset = 6.0 simulated sec = 300 ms real
' Packet retry = 2.0 simulated sec = 100 ms real

robust "Fire_Subsystem" as Fire
robust "Scheduler" as Scheduler
robust "Drone_1" as D1

@0
Fire is RUNNING
Scheduler is IDLE
D1 is IDLE

@0 <-> @700 : Scenario 1 - Stuck Mid-Flight
@0 <-> @100 : putRequest(req) notifyAll()
@100
Fire is TIMED_WAITING
Scheduler is DISPATCHING
D1 is EN_ROUTE

@100 <-> @300 : faultTriggerSeconds expires
@200
Scheduler is WAITING_FOR_DRONE

@300
D1 is RESETTING
@300 <-> @600 : wait(timeout) soft reset window

@600
Scheduler is WAITING_FOR_DRONE
D1 is EN_ROUTE

@700
Fire is RUNNING
Scheduler is IDLE
D1 is IDLE

@700 <-> @1300 : Scenario 2 - Nozzle Jammed
@700 <-> @800 : putRequest(req) notifyAll()
@800
Fire is TIMED_WAITING
Scheduler is DISPATCHING
D1 is EN_ROUTE

@900
Scheduler is WAITING_FOR_DRONE
D1 is DROPPING_AGENT

@900 <-> @1100 : hard fault timer reaches deadline
@1100
Scheduler is DISPATCHING
D1 is OFFLINE

@1100 <-> @1200 : handleHardFault(...)\nmission requeued and notifyAll()
@1200
Scheduler is WAITING_FOR_DRONE
D1 is OFFLINE

@1300
Fire is RUNNING
Scheduler is IDLE
D1 is IDLE

@1300 <-> @1800 : Scenario 3 - Packet Loss
@1300 <-> @1400 : putRequest(req) notifyAll()
@1400
Fire is TIMED_WAITING
Scheduler is DISPATCHING
D1 is EN_ROUTE

@1500
Scheduler is WAITING_FOR_DRONE
D1 is EN_ROUTE

@1500 <-> @1600 : first STATUS lost / corrupted
@1600 <-> @1700 : wait(timeout) retry delay

@1700
Scheduler is WAITING_FOR_DRONE
D1 is EN_ROUTE

@1800
Fire is TIMED_WAITING
Scheduler is WAITING_FOR_DRONE
D1 is EN_ROUTE

@enduml
